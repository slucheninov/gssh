# gssh configuration
# Space-separated GCP project IDs (required)
GSSH_PROJECTS="my-project-1 my-project-2"

# Space-separated GCP zones
# GSSH_ZONES="us-central1-a us-central1-b us-central1-c"

# Path to VM name cache
# GSSH_CACHE_FILE="${HOME}/.cache/gssh/vms"

# Cache lifetime in seconds (default: 86400 = 24h)
# GSSH_CACHE_TTL=86400

# Exclude VM names matching these prefixes (space-separated)
# GSSH_EXCLUDE_PREFIXES="gke-"

# GCP accounts for switching (space-separated emails)
# GSSH_ACCOUNTS="user1@gmail.com user2@company.com"
